{
  "kind": "collectionType",
  "collectionName": "shop_items",
  "info": {
    "singularName": "shop-item",
    "pluralName": "shop-items",
    "displayName": "Shop Item",
    "description": "Товары магазина наград, которые участники покупают за XP"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "order": { "type": "integer", "default": 1 },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "title": { "type": "string", "required": true },
    "description": { "type": "text" },
    "price": { "type": "integer", "required": true, "default": 100, "min": 0 },
    "image": { "type": "string", "required": true },
    "tag": { "type": "string", "default": "мерч" },
    "isActive": { "type": "boolean", "default": true }
  }
}
