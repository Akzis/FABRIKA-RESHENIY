{
  "kind": "collectionType",
  "collectionName": "daily_quests",
  "info": {
    "singularName": "daily-quest",
    "pluralName": "daily-quests",
    "displayName": "Daily quest",
    "description": "Дейли-задание"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "order": { "type": "integer", "default": 1 },
    "title": { "type": "string", "required": true },
    "description": { "type": "text" },
    "points": { "type": "integer", "required": true, "default": 50 },
    "date": { "type": "date" },
    "kind": {
      "type": "enumeration",
      "enum": ["action", "quiz"],
      "default": "action",
      "required": true
    },
    "options": { "type": "json" },
    "correctAnswer": { "type": "integer" }
  }
}
